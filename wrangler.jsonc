{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "llmwikiworker",
    "main": "src/index.js",
    "compatibility_date": "2026-04-18",
    "ai": {
        "binding": "AI",
    },
    "observability": {
        "enabled": true,
        "head_sampling_rate": 1,
        "logs": {
            "enabled": true,
            "head_sampling_rate": 1,
            "persist": true,
            "invocation_logs": true,
        },
        "traces": {
            "enabled": false,
            "persist": true,
            "head_sampling_rate": 1,
        },
    },
    "triggers": {
        "crons": ["0 10 * * *"],
    },
    "queues": {
        "producers": [
            {
                "binding": "LLM_WIKI_QUEUE",
                "queue": "llm-wiki-queue"
            }
        ],
        "consumers": [
            {
                "queue": "llm-wiki-queue",
                "max_batch_size": 1,
                "max_batch_timeout": 1,
                "max_retries": 2
            }
        ]
    },
    "vars": {
        "APP_TIMEZONE": "Asia/Taipei",
        "GITHUB_OWNER": "walle4561",
        "GITHUB_REPO": "LLM-Wiki",
        "GITHUB_REF": "main",
        "AI_MODEL": "@cf/google/gemma-4-26b-a4b-it"
    },
}
