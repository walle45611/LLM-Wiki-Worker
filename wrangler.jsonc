{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "llmwikiworker",
    "main": "src/index.js",
    "compatibility_date": "2026-04-18",
    "ai": {
        "binding": "AI",
    },
    "observability": {
        "enabled": true,
        "head_sampling_rate": 1,
        "logs": {
            "enabled": true,
            "head_sampling_rate": 1,
            "persist": true,
            "invocation_logs": true,
        },
        "traces": {
            "enabled": false,
            "persist": true,
            "head_sampling_rate": 1,
        },
    },
    "vars": {
        "APP_TIMEZONE": "Asia/Taipei",
        "GITHUB_OWNER": "walle4561",
        "GITHUB_REPO": "LLM-Wiki",
        "GITHUB_REF": "main",
        "GITHUB_FILE_PATH": "wiki/log.md",
        "GITHUB_INDEX_PATH": "wiki/index.md",
        "GITHUB_REVIEW_RULES_PATH": "wiki/rules/review-rules.md",
        "AI_MODEL": "@cf/openai/gpt-oss-20b",
    },
}
