{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "llmwikiworker",
    "main": "src/index.js",
    "compatibility_date": "2026-04-18",
    "ai": {
        "binding": "AI",
    },
    "observability": {
        "enabled": true,
        "head_sampling_rate": 1,
        "logs": {
            "enabled": true,
            "head_sampling_rate": 1,
            "persist": true,
            "invocation_logs": true,
        },
        "traces": {
            "enabled": false,
            "persist": true,
            "head_sampling_rate": 1,
        },
    },
    "triggers": {
        "crons": ["0 10 * * *"],
    },
    "vars": {
        "APP_TIMEZONE": "Asia/Taipei",
        "LINE_TARGET_USER_ID": "U666feedc6c76d6d033a0e19795b8d91d",
        "GITHUB_OWNER": "walle4561",
        "GITHUB_REPO": "LLM-Wiki",
        "GITHUB_REF": "main",
        "AI_MODEL": "@cf/openai/gpt-oss-20b"
    },
}
